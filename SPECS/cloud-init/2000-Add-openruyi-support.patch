From fa1b2179ca98479d8f060e0a707692de54c94ca4 Mon Sep 17 00:00:00 2001
From: Z572 <z572@z572.online>
Date: Mon, 29 Jun 2026 17:04:47 +0800
Subject: [PATCH] Add openruyi support

---
 cloudinit/config/cc_yum_add_repo.py     |  1 +
 cloudinit/distros/__init__.py           |  1 +
 cloudinit/distros/openruyi.py           |  9 +++++++++
 cloudinit/net/sysconfig.py              |  1 +
 cloudinit/util.py                       |  1 +
 config/cloud.cfg.tmpl                   | 10 +++++-----
 doc/rtd/reference/availability.rst      |  1 +
 doc/rtd/reference/network-config.rst    |  4 ++--
 doc/rtd/spelling_word_list.txt          |  1 +
 systemd/cloud-init-generator.tmpl       |  2 +-
 systemd/cloud-init-network.service.tmpl |  2 +-
 templates/hosts.openruyi.tmpl           | 24 ++++++++++++++++++++++++
 12 files changed, 48 insertions(+), 9 deletions(-)
 create mode 100644 cloudinit/distros/openruyi.py
