diff --git a/cloudinit/config/cc_yum_add_repo.py b/cloudinit/config/cc_yum_add_repo.py
index f20f7ea0..3920da60 100644
--- a/cloudinit/config/cc_yum_add_repo.py
+++ b/cloudinit/config/cc_yum_add_repo.py
@@ -30,6 +30,7 @@ meta: MetaSchema = {
         "openeuler",
         "OpenCloudOS",
         "openmandriva",
+        "openruyi",
         "photon",
         "rhel",
         "rocky",
diff --git a/cloudinit/distros/__init__.py b/cloudinit/distros/__init__.py
index 2c9daff2..afb5a832 100644
--- a/cloudinit/distros/__init__.py
+++ b/cloudinit/distros/__init__.py
@@ -97,6 +97,7 @@ OSFAMILIES = {
         "suse",
     ],
     "openeuler": ["openeuler"],
+    "openruyi": ["openRuyi", "openruyi"],
     "OpenCloudOS": ["OpenCloudOS", "TencentOS"],
 }
 
diff --git a/cloudinit/distros/openruyi.py b/cloudinit/distros/openruyi.py
new file mode 100644
index 00000000..b5dc985b
--- /dev/null
+++ b/cloudinit/distros/openruyi.py
@@ -0,0 +1,9 @@
+# This file is part of cloud-init. See LICENSE file for license information.
+
+from cloudinit.distros import rhel
+
+
+class Distro(rhel.Distro):
+    def __init__(self, name, cfg, paths):
+        super(Distro, self).__init__(name, cfg, paths)
+        self.osfamily = "openruyi"
diff --git a/cloudinit/net/sysconfig.py b/cloudinit/net/sysconfig.py
index 5d45babd..4f6d2283 100644
--- a/cloudinit/net/sysconfig.py
+++ b/cloudinit/net/sysconfig.py
@@ -30,6 +30,7 @@ KNOWN_DISTROS = [
     "openeuler",
     "OpenCloudOS",
     "openmandriva",
+    "openruyi",
     "rhel",
     "rocky",
     "suse",
diff --git a/cloudinit/util.py b/cloudinit/util.py
index 3e65c7ef..c7211111 100644
--- a/cloudinit/util.py
+++ b/cloudinit/util.py
@@ -626,6 +626,7 @@ def _get_variant(info):
             "openeuler",
             "opencloudos",
             "openmandriva",
+            "openruyi",
             "photon",
             "raspberry-pi-os",
             "rhel",
diff --git a/config/cloud.cfg.tmpl b/config/cloud.cfg.tmpl
index 96fe02ed..df0148d6 100644
--- a/config/cloud.cfg.tmpl
+++ b/config/cloud.cfg.tmpl
@@ -61,7 +61,7 @@ disable_root: false
 disable_root: true
 {% endif %}
 
-{%- if variant in ["alpine", "amazon", "fedora", "OpenCloudOS", "openeuler",
+{%- if variant in ["alpine", "amazon", "fedora", "OpenCloudOS", "openeuler", "openruyi",
                    "openmandriva", "photon", "TencentOS"] or is_rhel %}
 
 {% if is_rhel %}
@@ -171,7 +171,7 @@ cloud_config_modules:
 {% if variant == "ubuntu" %}
   - ubuntu_pro
 {% endif %}
-{% elif variant in ["azurelinux", "fedora", "mariner", "openeuler",
+{% elif variant in ["azurelinux", "fedora", "mariner", "openeuler", "openruyi",
                     "openmandriva", "photon"] or is_rhel %}
 {% if is_rhel %}
   - rh_subscription
@@ -235,7 +235,7 @@ system_info:
   # This will affect which distro class gets used
 {% if variant in ["alpine", "amazon", "aosc", "arch", "azurelinux", "debian", "fedora",
                   "freebsd", "gentoo", "mariner", "netbsd", "openbsd",
-                  "OpenCloudOS", "openeuler", "openmandriva", "photon",
+                  "OpenCloudOS", "openeuler", "openmandriva", "openruyi", "photon",
                   "raspberry-pi-os", "suse", "TencentOS", "ubuntu"] or is_rhel %}
   distro: {{ variant }}
 {% elif variant == "dragonfly" %}
@@ -252,7 +252,7 @@ system_info:
     name: {{ variant }}
 {% endif %}
 {% if variant in ["alpine", "amazon", "aosc", "arch", "azurelinux", "debian", "fedora",
-                  "gentoo", "mariner", "OpenCloudOS", "openeuler",
+                  "gentoo", "mariner", "OpenCloudOS", "openeuler", "openruyi",
                   "openmandriva", "photon", "raspberry-pi-os",
                   "suse", "TencentOS", "ubuntu", "unknown"]
                  or is_bsd or is_rhel %}
@@ -338,7 +338,7 @@ system_info:
   ntp_client: auto
 {% endif %}
 {% if variant in ["alpine", "amazon", "aosc", "arch", "azurelinux", "debian", "fedora",
-                  "gentoo", "mariner", "OpenCloudOS", "openeuler",
+                  "gentoo", "mariner", "OpenCloudOS", "openeuler", "openruyi",
                   "openmandriva", "photon", "suse", "TencentOS", "ubuntu",
                   "unknown"]
                   or is_rhel %}
