From 488f880a635fd5e19be9db48ae4c5c67b063cdc8 Mon Sep 17 00:00:00 2001
From: HNO3Miracle <xiangao.or@isrc.iscas.ac.cn>
Date: Tue, 2 Jun 2026 15:06:40 +0800
Subject: [PATCH] Skip credential-dependent storage tests

OBS has no Google Cloud credentials or GCE DirectPath environment. Gate the
credential-dependent storage tests behind a build tag and skip the remaining
credential-dependent case while keeping local and replay-safe checks enabled.
Only tests are changed; storage client runtime code is untouched.
---
 storage/grpc_dp_diag_test.go | 3 +++
 storage/grpc_metrics_test.go | 3 +++
 storage/http_client_test.go  | 1 +
 3 files changed, 7 insertions(+)

diff --git a/storage/grpc_dp_diag_test.go b/storage/grpc_dp_diag_test.go
index 142e027b..8af65372 100644
--- a/storage/grpc_dp_diag_test.go
+++ b/storage/grpc_dp_diag_test.go
@@ -1,3 +1,6 @@
+//go:build gcp_credentials
+// +build gcp_credentials
+
 // Copyright 2026 Google LLC
 //
 // Licensed under the Apache License, Version 2.0 (the "License");
diff --git a/storage/grpc_metrics_test.go b/storage/grpc_metrics_test.go
index d00a1f9b..1c97bbb6 100644
--- a/storage/grpc_metrics_test.go
+++ b/storage/grpc_metrics_test.go
@@ -1,3 +1,6 @@
+//go:build gcp_credentials
+// +build gcp_credentials
+
 // Copyright 2024 Google LLC
 //
 // Licensed under the Apache License, Version 2.0 (the "License");
diff --git a/storage/http_client_test.go b/storage/http_client_test.go
index 5301a335..8fd90c6b 100644
--- a/storage/http_client_test.go
+++ b/storage/http_client_test.go
@@ -97,6 +97,7 @@ func TestSetHeadersFromContext(t *testing.T) {
 }
 
 func TestAppendableWriteUnsupported(t *testing.T) {
+	t.Skip("requires Google Cloud default credentials in OBS")
 	ctx := context.Background()
 	c, err := newHTTPStorageClient(ctx)
 	if err != nil {
